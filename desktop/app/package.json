{
  "name": "rim-data-analysis-desktop",
  "version": "1.0.0",
  "description": "Electron desktop UI for Rim Data Analysis.",
  "author": "Xu Chenguang",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.node.json && vite build",
    "dist:win": "npm run build && electron-builder --win dir --x64",
    "pack:win": "npm run build && electron-builder --win dir --x64",
    "start": "npm run build && electron .",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "build": {
    "appId": "com.rimdataanalysis.desktop",
    "productName": "RimDataAnalysis",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "index.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/backend/rim-analysis-web-api.exe",
        "to": "backend/rim-analysis-web-api.exe"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "RimDataAnalysis-v${version}-windows-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
